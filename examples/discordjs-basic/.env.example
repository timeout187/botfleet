# Copy to .env and fill in - see docs/agent-installation.md for
# BOTFLEET_AGENT_SOCKET (the agent's local IPC socket path) and
# docs/runtime-sdk.md for the rest.
#
# A unique ID this bot is known by in BotFleet - not a Discord snowflake,
# just a stable identifier the control plane's Bot rows use.
BOTFLEET_BOT_ID=example-bot-1

# The agent's local Unix socket - matches BOTFLEET_AGENT_SOCKET_PATH on
# the agent process (apps/agent), default /tmp/botfleet-agent.sock.
BOTFLEET_AGENT_SOCKET=/tmp/botfleet-agent.sock

# Never commit a real token. Use a throwaway test bot's token, or leave
# blank to exercise everything except the actual Discord gateway login.
DISCORD_BOT_TOKEN=
