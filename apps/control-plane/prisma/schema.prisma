// BotFleet database schema.
// Learn more about Prisma: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  owner
  admin
  member
}

enum PlanTier {
  free
  starter
  pro
  enterprise
  custom
}

enum CustomerStatus {
  active
  suspended
  expired
}

enum BotStatus {
  online
  offline
  starting
  stopping
  failed
  disabled
  expired
  rate_limited
}

enum WorkerMode {
  pm2
  docker
}

enum WorkerStatus {
  online
  offline
  overloaded
  failed
  draining
}

enum AssignmentStatus {
  active
  draining
  removed
}

enum ShardStatus {
  connected
  connecting
  disconnected
  reconnecting
}

enum AlertSeverity {
  info
  warning
  error
  critical
}

enum AlertStatus {
  open
  acknowledged
  resolved
}

enum DeploymentStatus {
  pending
  in_progress
  success
  failed
  rolled_back
}

/// Mirrors @botfleet/protocol's AgentStatus - kept as a separate enum
/// (not a shared import) because Prisma enums can't be generated from an
/// external package; docs/distributed-audit.md's "migration risks" notes
/// this as a place the two need to be kept in sync by hand.
enum AgentStatus {
  enrolling
  online
  degraded
  disconnected
  draining
  maintenance
  disabled
}

enum AgentCredentialStatus {
  active
  revoked
  expired
}

// User fields split in two groups:
// - name/email/emailVerified/image are populated by @auth/prisma-adapter
//   from the Discord OAuth profile (Auth.js's standard adapter contract).
// - discordUserId/role are BotFleet's own fields, backfilled by the auth
//   session callback the first time a session is read for a new user.
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  discordUserId String?   @unique @map("discord_user_id")
  role          Role      @default(member)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  accounts         Account[]
  sessions         Session[]
  customers        Customer[]
  auditLogs        AuditLog[]
  deployments      Deployment[]      @relation("DeployedBy")
  enrollmentTokens EnrollmentToken[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Customer {
  id          String         @id @default(cuid())
  ownerUserId String         @map("owner_user_id")
  owner       User           @relation(fields: [ownerUserId], references: [id])
  name        String
  plan        PlanTier       @default(free)
  status      CustomerStatus @default(active)
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  bots Bot[]

  @@map("customers")
}

model Bot {
  id              String    @id @default(cuid())
  customerId      String    @map("customer_id")
  customer        Customer  @relation(fields: [customerId], references: [id])
  name            String
  clientId        String    @map("client_id")
  tokenEncrypted  String    @map("token_encrypted")
  publicKey       String?   @map("public_key")
  plan            PlanTier  @default(free)
  status          BotStatus @default(offline)
  guildLimit      Int       @default(100) @map("guild_limit")
  shardCount      Int       @default(1) @map("shard_count")
  workerGroupId   String?   @map("worker_group_id")
  workerGroup     Worker?   @relation(fields: [workerGroupId], references: [id])
  lastReadyAt     DateTime? @map("last_ready_at")
  lastHeartbeatAt DateTime? @map("last_heartbeat_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  health      BotHealth?
  shards      Shard[]
  assignments WorkerAssignment[]

  @@index([customerId])
  @@index([workerGroupId])
  @@map("bots")
}

model BotHealth {
  botId         String    @id @map("bot_id")
  bot           Bot       @relation(fields: [botId], references: [id], onDelete: Cascade)
  status        BotStatus @default(offline)
  guildCount    Int       @default(0) @map("guild_count")
  shardCount    Int       @default(1) @map("shard_count")
  pingMs        Int?      @map("ping_ms")
  memoryMb      Int?      @map("memory_mb")
  restartCount  Int       @default(0) @map("restart_count")
  lastErrorSafe String?   @map("last_error_safe")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@map("bot_health")
}

model Worker {
  id              String       @id @default(cuid())
  name            String
  mode            WorkerMode   @default(pm2)
  status          WorkerStatus @default(offline)
  host            String?
  maxBots         Int          @default(5) @map("max_bots")
  currentBots     Int          @default(0) @map("current_bots")
  memoryMb        Int?         @map("memory_mb")
  cpuPercent      Float?       @map("cpu_percent")
  lastHeartbeatAt DateTime?    @map("last_heartbeat_at")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  bots        Bot[]
  assignments WorkerAssignment[]

  @@map("workers")
}

model WorkerAssignment {
  id        String           @id @default(cuid())
  workerId  String           @map("worker_id")
  worker    Worker           @relation(fields: [workerId], references: [id])
  botId     String           @map("bot_id")
  bot       Bot              @relation(fields: [botId], references: [id])
  status    AssignmentStatus @default(active)
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  @@index([workerId])
  @@index([botId])
  @@map("worker_assignments")
}

model Shard {
  id              String      @id @default(cuid())
  botId           String      @map("bot_id")
  bot             Bot         @relation(fields: [botId], references: [id], onDelete: Cascade)
  shardId         Int         @map("shard_id")
  status          ShardStatus @default(disconnected)
  guildCount      Int         @default(0) @map("guild_count")
  pingMs          Int?        @map("ping_ms")
  reconnectCount  Int         @default(0) @map("reconnect_count")
  lastHeartbeatAt DateTime?   @map("last_heartbeat_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  @@unique([botId, shardId])
  @@map("shards")
}

model AuditLog {
  id           String   @id @default(cuid())
  actorUserId  String?  @map("actor_user_id")
  actor        User?    @relation(fields: [actorUserId], references: [id])
  action       String
  targetType   String   @map("target_type")
  targetId     String   @map("target_id")
  metadataJson Json?    @map("metadata_json")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([targetType, targetId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Alert {
  id        String        @id @default(cuid())
  eventType String        @map("event_type")
  severity  AlertSeverity @default(info)
  title     String
  message   String
  status    AlertStatus   @default(open)
  createdAt DateTime      @default(now()) @map("created_at")

  @@index([status])
  @@index([createdAt])
  @@map("alerts")
}

model WebhookDestination {
  id            String    @id @default(cuid())
  name          String
  urlEncrypted  String    @map("url_encrypted")
  enabled       Boolean   @default(true)
  eventsJson    Json      @map("events_json")
  lastSuccessAt DateTime? @map("last_success_at")
  lastFailureAt DateTime? @map("last_failure_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@map("webhook_destinations")
}

model Deployment {
  id           String           @id @default(cuid())
  version      String
  commitSha    String           @map("commit_sha")
  status       DeploymentStatus @default(pending)
  deployedById String?          @map("deployed_by")
  deployedBy   User?            @relation("DeployedBy", fields: [deployedById], references: [id])
  startedAt    DateTime?        @map("started_at")
  finishedAt   DateTime?        @map("finished_at")
  notes        String?

  @@map("deployments")
}

/// Singleton row (always id = "singleton") holding fleet-wide toggles that
/// need to be readable/writable at runtime without a redeploy.
model SystemState {
  id              String   @id
  maintenanceMode Boolean  @default(false) @map("maintenance_mode")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("system_state")
}

/// A remote BotFleet agent process (see apps/agent). Rows are created by
/// the agent gateway (lib/agent-gateway/*) when a valid EnrollmentToken is
/// presented - never created by hand through the admin UI, since an
/// Agent row without a real live process behind it would be exactly the
/// "descriptive metadata, not a connected reality" problem
/// docs/distributed-audit.md flags about today's Worker model.
model Agent {
  id                String      @id @default(cuid())
  name              String
  status            AgentStatus @default(enrolling)
  protocolVersion   Int         @map("protocol_version")
  agentVersion      String      @map("agent_version")
  environment       String?
  region            String?
  labelsJson        Json        @map("labels_json")
  capabilitiesJson  Json        @map("capabilities_json")
  hostname          String
  architecture      String
  operatingSystem   String      @map("operating_system")
  totalMemoryMb     Int?        @map("total_memory_mb")
  availableMemoryMb Int?        @map("available_memory_mb")
  cpuUsagePercent   Float?      @map("cpu_usage_percent")
  diskTotalMb       Int?        @map("disk_total_mb")
  diskAvailableMb   Int?        @map("disk_available_mb")
  lastHeartbeatAt   DateTime?   @map("last_heartbeat_at")
  enrolledAt        DateTime    @default(now()) @map("enrolled_at")
  disabledAt        DateTime?   @map("disabled_at")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  credentials AgentCredential[]

  @@index([status])
  @@map("agents")
}

/// The agent's connection secret, recorded only as a SHA-256 fingerprint -
/// see lib/agents/credential.ts's doc comment for exactly why this is a
/// disclosed, non-production placeholder for real mutual TLS.
model AgentCredential {
  id          String                @id @default(cuid())
  agentId     String                @map("agent_id")
  agent       Agent                 @relation(fields: [agentId], references: [id], onDelete: Cascade)
  fingerprint String                @unique
  status      AgentCredentialStatus @default(active)
  issuedAt    DateTime              @default(now()) @map("issued_at")
  expiresAt   DateTime?             @map("expires_at")
  revokedAt   DateTime?             @map("revoked_at")

  @@index([agentId])
  @@map("agent_credentials")
}

/// Single-use, expiring, hashed-at-rest token an admin generates
/// (POST /api/admin/agents/enrollment-tokens) and hands to a new agent
/// out of band. Never stored in plaintext - only its SHA-256 hash.
model EnrollmentToken {
  id               String    @id @default(cuid())
  tokenHash        String    @unique @map("token_hash")
  restrictionsJson Json?     @map("restrictions_json")
  expiresAt        DateTime  @map("expires_at")
  usedAt           DateTime? @map("used_at")
  usedByAgentId    String?   @map("used_by_agent_id")
  createdById      String?   @map("created_by_id")
  createdBy        User?     @relation(fields: [createdById], references: [id])
  createdAt        DateTime  @default(now()) @map("created_at")

  @@map("enrollment_tokens")
}
