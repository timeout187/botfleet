# Copy this file to .env and fill in real values. Never commit .env.

# --- Database -----------------------------------------------------------
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/botfleet_dev"

# --- Token vault ----------------------------------------------------------
# Generate with: openssl rand -base64 32
BOTFLEET_ENCRYPTION_KEY=

# --- Auth (Discord OAuth) --------------------------------------------------
# Create an app at https://discord.com/developers/applications, add
# <your-url>/api/auth/callback/discord as an OAuth2 redirect.
AUTH_DISCORD_ID=
AUTH_DISCORD_SECRET=
# Generate with: openssl rand -base64 32
AUTH_SECRET=
AUTH_URL="http://localhost:3000"

# Comma-separated Discord user IDs promoted to "owner" on first sign-in.
BOTFLEET_ADMIN_DISCORD_IDS=

# --- Optional: Redis (powers the AI worker queue - see `npm run worker:ai`) -
REDIS_URL="redis://127.0.0.1:6379"

# --- Optional: backups (checked by the Security Center, not automated yet) -
BOTFLEET_BACKUP_STORAGE_URL=
BOTFLEET_BACKUP_ENCRYPTION_KEY=

PORT=3000
